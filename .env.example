# Supabase
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# The service role key is NEVER used in the frontend.
# It lives ONLY in Supabase Edge Function secrets:
#   supabase secrets set SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Web Push — the public half of a VAPID key pair. Safe to expose in the
# client bundle (that's what "public" means here). Generate a pair with
# `npx web-push generate-vapid-keys`; the private half goes ONLY into
# Supabase Edge Function secrets (VAPID_PRIVATE_KEY), never here.
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key-here
